{
  "editable": true,
  "panels": [
    {
      "title": "Temperaturverlauf",
      "type": "timeseries",
      "gridPos": { "h": 14, "w": 16, "x": 0, "y": 0 },
      "id": 1,
      "datasource": { "type": "mysql", "uid": "mariadb" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 4,
            "showPoints": "auto",
            "axisLabel": "Temperatur"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue",  "value": null },
              { "color": "green", "value": 19 },
              { "color": "red",   "value": 26 }
            ]
          }
        }
      },
      "options": {
        "legend":  { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "mariadb" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT ts AS time, temperature FROM temperature_readings WHERE $__timeFilter(ts) ORDER BY ts",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Aktuelle Temperatur",
      "type": "stat",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 0 },
      "id": 2,
      "datasource": { "type": "mysql", "uid": "mariadb" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue",  "value": null },
              { "color": "green", "value": 19 },
              { "color": "red",   "value": 26 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "mariadb" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT temperature FROM temperature_readings ORDER BY ts DESC LIMIT 1",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Letzter Status",
      "type": "stat",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 7 },
      "id": 3,
      "datasource": { "type": "mysql", "uid": "mariadb" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "optimal":  { "text": "Optimal",     "index": 0 },
                "too_high": { "text": "Zu hoch",     "index": 1 },
                "too_low":  { "text": "Zu niedrig",  "index": 2 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "text", "value": null }]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "mariadb" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT status FROM temperature_readings ORDER BY ts DESC LIMIT 1",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["iot", "temperature"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "title": "Temperatur-Dashboard",
  "uid": "temp-dashboard"
}